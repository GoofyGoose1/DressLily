@model List<Product>

<h1>All Products</h1>

@if (TempData["Message"] != null)
{
    <div class="message-box">
        @TempData["Message"]
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const messageBox = document.querySelector(".message-box");
            if (messageBox) {
                setTimeout(function () {
                    messageBox.remove();
                }, 4000);
            }
        });
    </script>
}

<div class="products-grid">
@foreach (var product in Model)
{
    <div class="product-card">

        @if (!string.IsNullOrEmpty(product.ImageName))
        {
            <img
                src="/images/@product.ImageName"
                class="product-image" />
        }

        <h3>@product.Name</h3>
        <p>@product.GetCategory()</p>
        <p>$@product.Price</p>
        <p>Stock: @product.Quantity</p>

        <form asp-action="Buy" method="post">
            <input type="hidden" name="id" value="@product.Id" />
            <button type="submit">
                Buy
            </button>
        </form>

        <form asp-action="AddStock" method="post">
            <input type="hidden" name="id" value="@product.Id" />
            <input
                type="number"
                name="amount"
                placeholder="Add stock"
                min="1"
                required />
            <button type="submit">
                Add Stock
            </button>
        </form>

        @if (!product.IsDefaultProduct)
        {
            <form asp-action="DeleteProduct" method="post">
                <input type="hidden" name="id" value="@product.Id" />
                <button type="submit" class="delete-button">
                    Delete Product
                </button>
            </form>
        }
    </div>
}
</div>
