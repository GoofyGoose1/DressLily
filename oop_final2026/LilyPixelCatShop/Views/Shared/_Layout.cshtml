<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Lily Pixel Cat Shop</title>

    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <nav class="navbar">
        <div class="logo">
            Lily Pixel Cat Shop
        </div>

        <div class="nav-links">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <a asp-controller="Store" asp-action="Products">Products</a>
            <a asp-controller="Store" asp-action="AddProduct">Add Product</a>
            <a asp-controller="Store" asp-action="Report">Reports</a>
        </div>
    </nav>

    <main id="pageRoot" class="page-transition">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="footer-inner">
            <div class="footer-copy">Made with love and cat hairs. Lily, forever stylish, forever loved.</div>
            <div class="footer-meta">
                <span class="footer-tag">Powered by purrs</span>
                <span class="footer-dot">•</span>
                <span class="footer-note">Inspired by Lily</span>
                <span class="footer-heart">♥</span>
            </div>
        </div>
    </footer>

    <script src="~/js/store.js"></script>

</body>
</html>